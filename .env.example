# API Configuration
VITE_API_BASE=http://localhost:8888/app/wp-json
VITE_WP_HOME=http://localhost:8888/app

# Development/Production Environment
VITE_APP_ENV=development

# Development Mode Flags
# Set to 'true' to skip WordPress authentication check and use mock user
VITE_SKIP_AUTH_CHECK=true

# Set to 'true' to use mock data instead of WordPress AJAX endpoints
VITE_USE_MOCK_DATA=true
